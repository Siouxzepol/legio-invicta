rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // handles: public read; allow create on registration
    match /handles/{handle} {
      allow read: if true;
      allow create: if request.auth != null;
      allow update, delete: if false;
    }

    // Members: owner can write their own doc; jefe can write any
    match /members/{uid} {
      allow read: if request.auth != null;
      allow write: if request.auth != null && request.auth.uid == uid;
      allow update, delete: if request.auth != null &&
        get(/databases/$(database)/documents/members/$(request.auth.uid)).data.isJefe == true;
    }

    // Especialidad accesos: members can create/delete their own requests; jefe manages all
    match /especialidad_accesos/{docId} {
      allow read: if request.auth != null;
      allow create: if request.auth != null && request.resource.data.memberId == request.auth.uid;
      allow update: if request.auth != null &&
        get(/databases/$(database)/documents/members/$(request.auth.uid)).data.isJefe == true;
      allow delete: if request.auth != null &&
        (resource.data.memberId == request.auth.uid ||
         get(/databases/$(database)/documents/members/$(request.auth.uid)).data.isJefe == true);
    }

    // Operaciones: all members can update (asistencia); jefe can create/delete
    match /operaciones/{docId} {
      allow read: if request.auth != null;
      allow update: if request.auth != null;
      allow create, delete: if request.auth != null &&
        get(/databases/$(database)/documents/members/$(request.auth.uid)).data.isJefe == true;
    }

    // Foro hilos: members can create and edit/delete their own; jefe/mod can do anything
    match /foro_hilos/{docId} {
      allow read: if request.auth != null;
      allow create: if request.auth != null;
      allow update, delete: if request.auth != null &&
        (resource.data.autorId == request.auth.uid ||
         get(/databases/$(database)/documents/members/$(request.auth.uid)).data.isJefe == true);
    }

    // Foro respuestas: same as hilos
    match /foro_respuestas/{docId} {
      allow read: if request.auth != null;
      allow create: if request.auth != null;
      allow update, delete: if request.auth != null &&
        (resource.data.autorId == request.auth.uid ||
         get(/databases/$(database)/documents/members/$(request.auth.uid)).data.isJefe == true);
    }

    // All other collections: authenticated read; jefe write
    match /{collection}/{document} {
      allow read: if request.auth != null;
      allow write: if request.auth != null &&
        get(/databases/$(database)/documents/members/$(request.auth.uid)).data.isJefe == true;
    }
  }
}
